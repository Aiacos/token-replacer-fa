{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["@league-of-foundry-developers/foundry-vtt-types"],
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.js"],
  "exclude": ["node_modules", "releases"]
}
