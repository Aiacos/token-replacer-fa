{
  "name": "token-replacer-fa",
  "version": "2.12.5",
  "private": true,
  "type": "module",
  "description": "Foundry VTT module — Token artwork replacement with Forgotten Adventures tokens",
  "foundry": {
    "minimum": "13",
    "verified": "14"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint scripts/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --project jsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@league-of-foundry-developers/foundry-vtt-types": "^13.346.0-beta.20250812191140",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "fuse.js": "^7.1.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
